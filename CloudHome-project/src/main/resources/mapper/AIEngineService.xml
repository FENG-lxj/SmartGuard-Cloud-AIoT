<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chome.mapper.FurnitureMapper">

    <select id="getLocationsByIds" resultType="com.chome.domain.entity.Location">
        SELECT id, room_name FROM CHome_Location WHERE id IN
        <foreach collection="locationIdList" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>
